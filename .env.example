# Base de données PostgreSQL (ex: Neon, Supabase)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=change-me-min-32-chars-random-string
JWT_REFRESH_SECRET=change-me-min-32-chars-random-string

# URL du frontend (pour CORS) — sur Vercel: https://votre-projet.vercel.app
FRONTEND_URL=https://votre-projet.vercel.app

# Environnement
NODE_ENV=production
